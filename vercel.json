{
    "buildCommand": "npm run build",
    "outputDirectory": "release-cloudflare",
    "installCommand": "npm ci",
    "cleanUrls": true,
    "trailingSlash": false,
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": "https://nexuradata-ai.pages.dev/api/:path*"
        }
    ]
}
