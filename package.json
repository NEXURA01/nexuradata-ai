{
  "name": "nexuradata-ai",
  "private": true,
  "config": {
    "pagesProjectName": "nexuradata-ai"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "build:next": "next build",
    "build": "node ./scripts/sync-release.mjs",
    "cf:sync": "npm run build",
    "cf:check": "npm run build && node ./scripts/pages-cli.mjs check",
    "cf:deploy": "npm run cf:pages:deploy:prod",
    "cf:deploy:staging": "npm run cf:pages:deploy:staging",
    "cf:dev": "npm run build && wrangler pages dev ./release-cloudflare --compatibility-date 2026-04-04 --live-reload",
    "cf:pages:list": "wrangler pages project list",
    "cf:pages:project:create": "node ./scripts/pages-cli.mjs create",
    "cf:pages:deploy:prod": "npm run build && node ./scripts/pages-cli.mjs deploy-prod",
    "cf:pages:deploy:staging": "npm run build && node ./scripts/pages-cli.mjs deploy-staging",
    "cf:domains:sync": "node ./scripts/sync-cloudflare-domains.mjs",
    "cf:whoami": "wrangler whoami",
    "vercel:projects": "vercel project ls",
    "vercel:link": "vercel link --yes --scope team_kIVkCxaqcjphHjaAV2tg7xl3 --project nexuradata-ai",
    "vercel:mcp": "vercel mcp --clients \"VS Code with Copilot\" --project --non-interactive",
    "vercel:pull": "vercel pull --yes",
    "vercel:deploy": "npm run build && vercel deploy --prod",
    "seo:sitemap": "node ./scripts/generate-sitemap.mjs",
    "supabase:link": "supabase link --project-ref amddiekyhrvxnzszugxb",
    "supabase:status": "supabase status",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop --no-backup",
    "supabase:db:push": "supabase db push --linked",
    "supabase:db:dry-run": "supabase db push --linked --dry-run",
    "supabase:db:diff": "supabase db diff",
    "supabase:db:diff:linked": "supabase db diff --linked",
    "supabase:db:dump:local": "supabase db dump --local --data-only -f supabase/seed.sql",
    "supabase:functions:download": "supabase functions download --project-ref amddiekyhrvxnzszugxb --use-api",
    "supabase:functions:download:summarize-thread": "supabase functions download summarize-thread --project-ref amddiekyhrvxnzszugxb --use-api",
    "supabase:functions:deploy:estimate": "supabase functions deploy estimate --project-ref amddiekyhrvxnzszugxb",
    "supabase:secrets:set": "supabase secrets set --project-ref amddiekyhrvxnzszugxb",
    "supabase:secrets:list": "supabase secrets list --project-ref amddiekyhrvxnzszugxb",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "node ./scripts/check.mjs",
    "prepare": "node ./scripts/setup-hooks.mjs"
  },
  "devDependencies": {
    "@types/node": "25.7.0",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "supabase": "^2.98.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.84.0"
  },
  "dependencies": {
    "@ai-sdk/react": "^3.0.182",
    "@base-ui/react": "^1.4.1",
    "@neondatabase/serverless": "^1.1.0",
    "@streamdown/cjk": "^1.0.3",
    "@streamdown/code": "^1.1.1",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "ai": "^6.0.180",
    "autoprefixer": "^10.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.11",
    "next": "^16.2.6",
    "next-intl": "^4.11.2",
    "postcss": "^8.5.14",
    "postgres": "^3.4.9",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "streamdown": "^2.5.0",
    "stripe": "^22.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "use-stick-to-bottom": "^1.1.4",
    "zod": "^4.4.3"
  }
}
