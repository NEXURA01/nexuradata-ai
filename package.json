{
  "name": "nexuradata-ai",
  "private": true,
  "config": {
    "pagesProjectName": "nexuradata-ai"
  },
  "scripts": {
    "build": "node ./scripts/sync-release.mjs",
    "cf:sync": "npm run build",
    "cf:check": "npm run build && node ./scripts/pages-cli.mjs check",
    "cf:deploy": "npm run cf:pages:deploy:prod",
    "cf:deploy:staging": "npm run cf:pages:deploy:staging",
    "cf:dev": "npm run build && wrangler pages dev ./release-cloudflare --compatibility-date 2026-04-04 --live-reload",
    "cf:pages:list": "wrangler pages project list",
    "cf:pages:project:create": "node ./scripts/pages-cli.mjs create",
    "cf:pages:deploy:prod": "npm run build && node ./scripts/pages-cli.mjs deploy-prod",
    "cf:pages:deploy:staging": "npm run build && node ./scripts/pages-cli.mjs deploy-staging",
    "cf:domains:sync": "node ./scripts/sync-cloudflare-domains.mjs",
    "cf:whoami": "wrangler whoami",
    "seo:sitemap": "node ./scripts/generate-sitemap.mjs",
    "supabase:link": "supabase link --project-ref amddiekyhrvxnzszugxb",
    "supabase:db:push": "supabase db push --linked",
    "supabase:db:dry-run": "supabase db push --linked --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "node ./scripts/check.mjs",
    "prepare": "node ./scripts/setup-hooks.mjs"
  },
  "devDependencies": {
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "supabase": "^2.98.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.84.0"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "postgres": "^3.4.9",
    "stripe": "^22.1.1"
  }
}
