{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "nexuradata-ai",
  "pages_build_output_dir": "./release-cloudflare",
  "compatibility_date": "2026-04-04",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "PUBLIC_SITE_ORIGIN": "https://nexuradata.ca",
    "TEAM_INBOX_EMAILS": "dany@nexuradata.ca,olivier@nexuradata.ca,contact@nexuradata.ca",
    "RESEND_FROM_EMAIL": "NEXURA <dossiers@nexuradata.ca>",
    "OPS_ACCESS_ALLOWED_DOMAIN": "nexuradata.ca"
  }
}
