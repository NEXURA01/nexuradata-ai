{
    "framework": "nextjs",
    "buildCommand": "npm run build",
    "installCommand": "npm ci",
    "cleanUrls": true,
    "trailingSlash": false,
    "crons": [
        {
            "path": "/api/lead-followup",
            "schedule": "0 14 * * *"
        }
    ],
    "redirects": [
        {
            "source": "/employe",
            "destination": "/fr/employe",
            "permanent": false
        },
        {
            "source": "/portal",
            "destination": "/fr/contact",
            "permanent": false
        },
        {
            "source": "/portal.html",
            "destination": "/fr/contact",
            "permanent": false
        },
        {
            "source": "/trust",
            "destination": "/fr/services",
            "permanent": true
        },
        {
            "source": "/security",
            "destination": "/fr/services",
            "permanent": true
        },
        {
            "source": "/web-protection",
            "destination": "/fr/services",
            "permanent": true
        },
        {
            "source": "/cipher",
            "destination": "/fr/services",
            "permanent": true
        },
        {
            "source": "/certificate",
            "destination": "/fr/services",
            "permanent": true
        },
        {
            "source": "/ai-certificate",
            "destination": "/fr/services",
            "permanent": true
        }
    ]
}